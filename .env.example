# Database
DATABASE_URL=postgresql://mohio:password@localhost:5432/mohio

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# LLM (llama-server compatible endpoint)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=

# Embeddings (llama-server compatible endpoint)
EMBED_BASE_URL=http://localhost:8081/v1
EMBED_MODEL=
EMBED_DIMS=768

# OIDC / SSO (e.g. Keycloak)
OIDC_ISSUER=https://auth.example.com/realms/mohio
OIDC_AUDIENCE=mohio

# Credential encryption (AES-256-GCM key for integration credentials)
# Generate: openssl rand -hex 32
CREDENTIALS_KEY=

# Server
PORT=9000
ALLOWED_ORIGIN=http://localhost:5173

# Optional: Claude/OpenAI for wiki ingest/query (if not using local LLM)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
